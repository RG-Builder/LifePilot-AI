rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase UID)
    // Fields:
    //   - firebase_uid: string (required)
    //   - email: string (required, email format)
    //   - subscription_plan: string (trial, premium)
    //   - role: string (admin, user)
    //   - trial_used: int
    //   - created_at: timestamp
    //
    // Collection: users/{userId}/tasks
    // Document ID: {taskId}
    // Fields:
    //   - user_id: string (required, matches parent userId)
    //   - title: string (required, max 200 chars)
    //   - importance: int (1-10)
    //   - urgency_score: int (1-10)
    //   - estimated_effort: int (1-10)
    //   - impact_level: int (1-10)
    //   - duration: int (positive)
    //   - status: string (pending, completed, overdue)
    //   - is_habit: bool
    //   - streak: int
    //   - deadline: timestamp
    //   - category: string
    //   - completed_at: timestamp
    //   - created_at: timestamp
    //
    // Collection: users/{userId}/habits
    // Document ID: {habitId}
    // Fields:
    //   - user_id: string
    //   - title: string
    //   - description: string
    //   - frequency: string (daily, weekly)
    //   - goal_count: int
    //   - current_count: int
    //   - streak: int
    //   - last_completed_at: timestamp
    //   - created_at: timestamp
    //
    // Collection: users/{userId}/goals
    // Document ID: {goalId}
    // Fields:
    //   - user_id: string
    //   - title: string
    //   - description: string
    //   - type: string (short-term, long-term)
    //   - status: string (active, achieved, paused)
    //   - target_date: timestamp
    //   - created_at: timestamp
    //
    // Collection: users/{userId}/focus_sessions
    // Document ID: {sessionId}
    // Fields:
    //   - user_id: string
    //   - task_id: string
    //   - start_time: timestamp
    //   - end_time: timestamp
    //   - duration_minutes: int
    //   - distractions_count: int
    //   - efficiency_score: int
    //
    // Collection: users/{userId}/ai_insights
    // Document ID: {insightId}
    // Fields:
    //   - user_id: string
    //   - insight_text: string
    //   - type: string
    //   - is_read: bool
    //   - created_at: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "realprouser1234@gmail.com" && request.auth.token.email_verified == true ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
